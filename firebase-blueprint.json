{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number", "description": "Timestamp in ms" }
      },
      "required": ["name", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "A product for sale",
      "type": "object",
      "properties": {
        "catId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "image": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "price", "stock", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Placed", "Dispatched", "Delivered", "Cancelled"] },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "totalAmount", "status", "items"]
    },
    "Offer": {
      "title": "Offer",
      "description": "A promotional offer banner",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string" },
        "active": { "type": "boolean" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "text", "active"]
    }
  },
  "firestore": {
    "/offers/{offerId}": {
      "schema": { "$ref": "#/entities/Offer" },
      "description": "Cart promotional offers"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products for sale"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    }
  }
}
